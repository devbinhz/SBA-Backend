# Database configuration (used by both Spring Boot and Docker Compose)
POSTGRES_DB=bookverse
POSTGRES_USER=bookverse
POSTGRES_PASSWORD=bookverse
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bookverse
SPRING_DATASOURCE_USERNAME=bookverse
SPRING_DATASOURCE_PASSWORD=bookverse

# Redis configuration
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Browser access
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sba-frontend-phi.vercel.app,https://sba-frontend-ten.vercel.app/

# Server configuration
SERVER_PORT=8080

# Use "local,reset" only when intentionally rebuilding and reseeding demo data.
SPRING_PROFILES_ACTIVE=local

# Admin seeder configuration
BOOKVERSE_ADMIN_EMAIL=admin@bookverse.local
BOOKVERSE_ADMIN_PASSWORD=ChangeMe123!
BOOKVERSE_ADMIN_FULL_NAME=BookVerse Admin

# Security & JWT configuration
JWT_SECRET=change-me-at-least-32-bytes-change-me
JWT_ACCESS_EXPIRATION_MS=900000
REFRESH_TOKEN_EXPIRATION_MS=2592000000
REFRESH_TOKEN_BYTES=32

# MinIO media storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BOOKS_BUCKET=bookverse-books
MINIO_THUMBNAILS_BUCKET=bookverse-thumbnails

# AI/RAG service
RAG_BASE_URL=http://localhost:8000
RAG_TIMEOUT_MS=300000
OPENAI_API_KEY=

# OTP configuration
OTP_EXPIRATION_MS=600000

# SMTP mail configuration
# Gmail example: use an App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=BookVerse <your-email@gmail.com>
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true

# VNPAY configuration
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment/result
VNPAY_CANCEL_URL=http://localhost:5173/payment/cancel
# Configure this URL in the VNPAY merchant/sandbox portal as IPN/Webhook.
# Spring Boot receives callbacks here but does not read this variable directly.
VNPAY_IPN_URL=https://your-public-backend-domain/api/v1/payments/vnpay/webhook

# Order configuration
SHIPPING_FEE_VND=30000
ORDER_EXPIRATION_MINUTES=15

# Guest track URL for emails
GUEST_TRACK_URL=http://localhost:5173/orders/track

# Scheduler configuration
EXPIRED_ORDER_SCHEDULER_FIXED_DELAY_MS=60000
EXPIRED_ORDER_SCHEDULER_BATCH_SIZE=50
